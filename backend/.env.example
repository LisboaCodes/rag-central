# ── Banco (LXC 100 — postgres-db) ─────────────────────────────
DATABASE_URL=postgresql://postgres:SENHA@IP_LXC100:5432/postgres

# ── OpenAI (fallback, pago) ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Chat global (provedor OpenAI-compatible: MiMo/Groq/OpenAI...) ─
CHAT_PROVIDER=openai
CHAT_API_BASE=https://api.xiaomimimo.com/v1
CHAT_API_KEY=
CHAT_MODEL=mimo-v2.5-pro

# ── Anthropic API (provedor "anthropic" — Claude via API, não CLI) ─
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ollama (preferencial, LXC 101) ────────────────────────────
OLLAMA_URL=http://IP_LXC101:11434
OLLAMA_MODEL=nomic-embed-text

# ── Embedding ─────────────────────────────────────────────────
# auto   = tenta Ollama, cai pra OpenAI se falhar
# ollama = só Ollama (erro se offline)
# openai = só OpenAI
EMBEDDING_MODE=auto
# dimensão da coluna vector no banco (Ollama 768 é preenchido
# com zeros até 1536 — ver README)
EMBEDDING_DIMS=1536

# ── Chunking (padrões, ajustáveis por request e no dashboard) ─
CHUNK_SIZE=512
CHUNK_OVERLAP=64
# tokens (aprox. 4 chars/token) ou chars
CHUNK_UNIT=tokens

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# arquivo onde o dashboard persiste configurações em runtime
# SETTINGS_FILE=./runtime-settings.json

# ── email-api (serviço central de e-mail) ─────────────────────
# O RAG não fala com o Resend: manda pro email-api com a chave DELE.
EMAIL_API_URL=https://send.creativenext.dev
EMAIL_API_KEY=
# Agentes autorizados a usar a ferramenta enviar_email (csv)
EMAIL_AGENT_KEYS=DARLENE
