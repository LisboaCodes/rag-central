#!/usr/bin/env python3
"""
oc-wizard-engine — backend de estado para o configurador de agentes do OpenClaw.

Faz todas as mudanças no ~/.openclaw/openclaw.json (com backup automático),
grava API keys, registra providers novos, reinicia o gateway e roda probes.
A UI (oc-wizard, em whiptail) chama estes subcomandos.

Subcomandos:
  ctx                      -> imprime JSON {models,channels,agents,providers,presets}
  apply-agent              -> cria/edita um agente
  add-provider             -> registra um provider de IA novo (+ key via stdin)
  restart                  -> reinicia o gateway (systemd)
  probe [MODEL]            -> probe ao vivo (todos ou um modelo)
  selftest                 -> valida a lógica num config temporário (não toca no real)
"""
import argparse, json, os, shutil, subprocess, sys, time

